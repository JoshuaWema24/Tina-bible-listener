# .env.example — copy to .env and fill in your values
# -------------------------------------------------------

# EasyWorship Companion settings
EW_HOST=127.0.0.1
EW_PORT=7979

# Enable verbose debug logging (0/1)
DEBUG=0

# Audio device index (leave empty for system default)
# Run: python main.py --list-devices  to find your mic index
# AUDIO_DEVICE_INDEX=

# Whisper model (tiny/base/small/medium/large-v3)
# WHISPER_MODEL=base

# Compute device (cpu/cuda)
# WHISPER_DEVICE=cpu
